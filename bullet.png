def load_image_safe(path, size=None):
    if not os.path.exists(path):
        return None
    try:
        img = pygame.image.load(path).convert_alpha()
        if size:
            img = pygame.transform.smoothscale(img, size)
        return img
    except Exception as e:
        print(f"Image load failed: {path} -> {e}")
        return None


def load_sound_safe(path, volume=0.5):
    if not audio_ok or not os.path.exists(path):
        return None
    try:
        snd = pygame.mixer.Sound(path)
        snd.set_volume(volume)
        return snd
    except Exception as e:
        print(f"Sound load failed: {path} -> {e}")
        return None


def draw_text(text, color, x, y, use_small=False):
    use_font = small_font if use_small else font
    img = use_font.render(text, True, color)
    screen.blit(img, (x, y))


def draw_center_text(text, color, y, use_big=False):
    use_font = big_font if use_big else font
    img = use_font.render(text, True, color)
    rect = img.get_rect(center=(WIDTH // 2, y))
    screen.blit(img, rect)


def clamp(value, minimum, maximum):
    return max(minimum, min(maximum, value))


def lerp(a, b, factor):
    return a + (b - a) * factor


def format_seconds(total_seconds):
    minutes = int(total_seconds) // 60
    seconds = int(total_seconds) % 60
    return f"{minutes:02d}:{seconds:02d}"


def draw_vertical_gradient(surface, top_color, bottom_color):
    for y in range(surface.get_height()):
        ratio = y / max(1, surface.get_height() - 1)
        color = (
            int(lerp(top_color[0], bottom_color[0], ratio)),
            int(lerp(top_color[1], bottom_color[1], ratio)),
            int(lerp(top_color[2], bottom_color[2], ratio)),
        )
        pygame.draw.line(surface, color, (0, y), (surface.get_width(), y))


def distance(a, b):
    return math.hypot(a[0] - b[0], a[1] - b[1])


def angle_to_vector(angle):
    return math.cos(angle), math.sin(angle)


def normalize_vector(dx, dy):
    length = math.hypot(dx, dy)
    if length == 0:
        return 0, 0
    return dx / length, dy / length


def point_in_circle(point, center, radius):
    return distance(point, center) <= radius


def line_intersects_rect(start, end, rect):
    clipped = rect.clipline(start, end)
    return bool(clipped)


def move_with_collisions(entity_rect, dx, dy, walls):
    entity_rect.x += int(dx)
    for wall in walls:
        if entity_rect.colliderect(wall):
            if dx > 0:
                entity_rect.right = wall.left
            elif dx < 0:
                entity_rect.left = wall.right

    entity_rect.y += int(dy)
    for wall in walls:
        if entity_rect.colliderect(wall):
            if dy > 0:
                entity_rect.bottom = wall.top
            elif dy < 0:
                entity_rect.top = wall.bottom

    entity_rect.x = clamp(entity_rect.x, 0, WIDTH - entity_rect.width)
    entity_rect.y = clamp(entity_rect.y, 0, HEIGHT - entity_rect.height)
    return entity_rect


def draw_entity(surface, image, rect, fallback_color, border_color):
    if image:
        sprite = pygame.transform.smoothscale(image, (rect.width, rect.height))
        surface.blit(sprite, rect.topleft)
    else:
        pygame.draw.rect(surface, fallback_color, rect, border_radius=12)
        pygame.draw.rect(surface, border_color, rect, 2, border_radius=12)


